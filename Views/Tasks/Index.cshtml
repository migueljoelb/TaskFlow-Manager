@model IEnumerable<dynamic>
@{
    Layout = "_Layout";
}

<h2>Tareas</h2>
<p>
    <a asp-action="Create">Crear nueva tarea</a>
</p>
<table>
    <thead>
        <tr>
            <th>Título</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null)
        {
            foreach (var item in Model)
            {
                <tr>
                    <td>@item.Title</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id">Editar</a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr><td colspan="2">No hay tareas para mostrar.</td></tr>
        }
    </tbody>
</table>
