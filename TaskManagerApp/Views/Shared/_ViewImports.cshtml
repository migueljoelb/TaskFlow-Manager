@using TaskManagerApp
@using TaskManagerApp.Models
@using TaskManagerApp.ViewModels
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Task Manager</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>

    @* Navbar — solo visible si hay sesión activa *@
    @if (Context.Session.GetInt32("UserId") != null)
    {
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
            <div class="container">
                <a class="navbar-brand" href="/Tasks">📋 Task Manager</a>
                <div class="ms-auto d-flex align-items-center gap-3">
                    <span class="text-white">
                        👤 @Context.Session.GetString("UserName")
                    </span>
                    <a href="/Account/Logout" class="btn btn-outline-light btn-sm">
                        Cerrar sesión
                    </a>
                </div>
            </div>
        </nav>
    }

    <main class="container mt-4">
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>