@model List<TaskManagerApp.Models.TaskItem>
@{
    ViewData["Title"] = "Mis Tareas";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>📋 Mis Tareas</h2>
    <a asp-action="Create" class="btn btn-primary">+ Nueva Tarea</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info text-center">
        No tienes tareas aún. ¡Crea tu primera tarea!
    </div>
}
else
{
    <div class="row">
        @foreach (var task in Model)
        {
            <div class="col-md-4 mb-3">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <h5 class="card-title">@task.Title</h5>

                            @* Badge de estado con color *@
                            @{
                                var badgeClass = task.Status switch
                                {
                                    TaskManagerApp.Models.TaskStatus.Pendiente => "bg-warning text-dark",
                                    TaskManagerApp.Models.TaskStatus.EnProceso => "bg-primary",
                                    TaskManagerApp.Models.TaskStatus.Completada => "bg-success",
                                    _ => "bg-secondary"
                                };
                            }
                            <span class="badge @badgeClass">@task.Status</span>
                        </div>

                        <p class="card-text text-muted mt-2">
                            @(string.IsNullOrEmpty(task.Description)
                                ? "Sin descripción"
                                : task.Description)
                        </p>

                        <small class="text-muted">
                            Creada: @task.CreatedAt.ToString("dd/MM/yyyy")
                        </small>
                    </div>

                    <div class="card-footer d-flex gap-2">
                        <a asp-action="Edit" asp-route-id="@task.Id"
                               class="btn btn-sm btn-outline-primary w-50">
                            ✏️ Editar
                        </a>

                        <form asp-action="Delete" asp-route-id="@task.Id"
                              method="post" class="w-50"
                              onsubmit="return confirm('¿Eliminar esta tarea?')">
                            <button type="submit" class="btn btn-sm btn-outline-danger w-100">
                                🗑️ Eliminar
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}